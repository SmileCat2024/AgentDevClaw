{
  "id": "programming-helper",
  "kind": "agent",
  "name": "编程小助手",
  "description": "面向真实编码任务的编程工作空间，支持理解代码、实现功能、排障和重构",
  "version": "2.0.0",
  "icon": "code",
  "category": "development",
  "enabled": true,
  "modelPresets": {
    "default": "小米Mimo-V2.5-Pro",
    "exploration": "小米Mimo-V2.5-Pro",
    "sub": "小米Mimo-V2.5-Pro",
    "system": "小米Mimo-V2.5-Pro"
  },
  "features": [
    "todo",
    "audit",
    "audio-feedback",
    "user-input",
    "websearch",
    "memory",
    "shell",
    "lsp",
    "mcp",
    "skill"
  ],
  "identities": [
    {
      "id": "main",
      "displayName": "编程小助手",
      "description": "擅长编码、调试、重构，支持完整工具链",
      "sessionModel": "persistent",
      "qualifierLabel": "项目",
      "groupChat": true,
      "operations": [
        "status",
        "sessions",
        "send",
        "interrupt",
        "create",
        "overview",
        "explorations"
      ]
    },
    {
      "id": "explorer",
      "displayName": "探索代理",
      "description": "只读分析、知识收集，不可修改文件",
      "sessionModel": "one-shot",
      "groupChat": true,
      "operations": [
        "status",
        "spawn",
        "compact"
      ]
    }
  ],
  "ui": {
    "entry": "sessions",
    "tabs": [
      {
        "id": "sessions",
        "label": {
          "zh": "项目",
          "en": "Projects"
        }
      },
      {
        "id": "chat",
        "label": {
          "zh": "对话",
          "en": "Chat"
        }
      }
    ],
    "home": {
      "blocks": [
        {
          "id": "session-list",
          "type": "session-list",
          "visibility": "tab:sessions",
          "title": {
            "zh": "项目记录",
            "en": "Project Sessions"
          },
          "description": {
            "zh": "继续之前的对话，或开始一段新的编码会话。",
            "en": "Resume a prior conversation or start a new coding session."
          },
          "headerAction": {
            "label": {
              "zh": "新对话",
              "en": "New Chat"
            },
            "action": {
              "type": "create_session",
              "openDirectory": ""
            }
          }
        }
      ]
    }
  }
}