{
  "id": "qqbot",
  "kind": "agent",
  "name": "IM 渠道",
  "description": "为不同身份配置 IM 渠道与上下文，当前先支持接待员身份",
  "version": "1.0.0",
  "icon": "qq",
  "category": "chatbot",
  "enabled": true,
  "features": ["qqbot", "weixin-bot", "todo", "audit", "websearch", "shell", "user-input", "mcp", "skill", "subagent"],
  "ui": {
    "entry": "home",
    "tabs": [
      {
        "id": "home",
        "label": {
          "zh": "首页",
          "en": "Home"
        }
      },
      {
        "id": "chat",
        "label": {
          "zh": "对话",
          "en": "Chat"
        }
      }
    ],
    "home": {
      "blocks": [
        {
          "id": "hero",
          "type": "hero",
          "title": {
            "zh": "IM 渠道",
            "en": "IM Channels"
          },
          "body": {
            "zh": "先维护各个 IM 渠道的绑定信息，再按身份选择上下文与渠道。当前先开放接待员身份，点击它的对话即可按当前配置启动。",
            "en": "Maintain IM channel bindings first, then choose context and channel per identity. The receptionist identity is available for now."
          }
        },
        {
          "id": "im-workspace-config",
          "type": "config-editor",
          "configEditor": {
            "type": "im-workspace",
            "title": {
              "zh": "接待员身份配置",
              "en": "Receptionist Identity Config"
            },
            "description": {
              "zh": "先给接待员身份选择上下文，再决定它当前通过哪条渠道对外工作。",
              "en": "Assign context to the receptionist identity first, then choose which channel it should use."
            },
            "fields": [
              {
                "name": "appId",
                "type": "text",
                "label": {
                  "zh": "App ID",
                  "en": "App ID"
                }
              },
              {
                "name": "clientSecret",
                "type": "password",
                "label": {
                  "zh": "Client Secret",
                  "en": "Client Secret"
                }
              },
              {
                "name": "accountId",
                "type": "text",
                "label": {
                  "zh": "Account ID",
                  "en": "Account ID"
                }
              },
              {
                "name": "markdownSupport",
                "type": "checkbox",
                "label": {
                  "zh": "启用 Markdown",
                  "en": "Enable Markdown"
                }
              }
            ]
          }
        }
      ]
    }
  }
}
