{
  "id": "programming-helper",
  "kind": "agent",
  "name": "编程小助手",
  "description": "面向真实编码任务的编程工作空间，支持理解代码、实现功能、排障和重构",
  "version": "2.0.0",
  "icon": "code",
  "category": "development",
  "enabled": true,
  "features": [
    "todo",
    "audit",
    "audio-feedback",
    "user-input",
    "websearch",
    "memory",
    "shell",
    "mcp",
    "skill",
    "subagent"
  ],
  "ui": {
    "entry": "sessions",
    "tabs": [
      {
        "id": "sessions",
        "label": {
          "zh": "对话",
          "en": "Sessions"
        }
      },
      {
        "id": "chat",
        "label": {
          "zh": "聊天",
          "en": "Chat"
        }
      }
    ],
    "home": {
      "blocks": [
        {
          "id": "session-list",
          "type": "session-list",
          "visibility": "tab:sessions",
          "title": {
            "zh": "对话记录",
            "en": "Sessions"
          },
          "description": {
            "zh": "继续之前的对话，或开始一段新的编码会话。",
            "en": "Resume a prior conversation or start a new coding session."
          },
          "headerAction": {
            "label": {
              "zh": "新对话",
              "en": "New Chat"
            },
            "action": {
              "type": "create_session",
              "openDirectory": ""
            }
          }
        }
      ]
    }
  }
}
