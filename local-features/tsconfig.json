{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist"
  },
  "include": [
    "./index.ts",
    "./context-compaction-control/src/**/*.ts",
    "./context-compaction-mirror/src/**/*.ts",
    "./context-compaction-mirror/test/**/*.ts",
    "./context-handoff-seed/src/**/*.ts",
    "./context-handoff-seed/test/**/*.ts",
    "./feature-dev/src/**/*.ts",
    "./agent-dev/src/**/*.ts",
    "./flow/src/**/*.ts",
    "./flow/test/**/*.ts",
    "./dispatch/src/**/*.ts",
    "./dispatch/test/**/*.ts",
    "./conversation-export/src/**/*.ts",
    "./checkpoint/src/**/*.ts",
    "./checkpoint/test/**/*.ts"
  ]
}
