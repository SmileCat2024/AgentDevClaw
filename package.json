{
  "name": "agentdevclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pure web ProtoClaw-style debugger UI built on top of AgentDev ViewerWorker.",
  "scripts": {
    "build:local-features": "npx tsc -p local-features/tsconfig.json && node scripts/copy-local-feature-skills.mjs",
    "enrich:features": "node scripts/enrich-feature-packages.mjs",
    "predev": "npm run build:local-features",
    "dev": "node server.js",
    "prestart": "npm run build:local-features",
    "start": "node server.js",
    "test": "node --test test/*.test.js && node local-features/dist/flow/test/flow-feature.test.js && node local-features/dist/context-compaction-mirror/test/smoke.test.js && node local-features/dist/checkpoint/test/smoke.test.js && node local-features/dist/dispatch/test/smoke.test.js && node local-features/dist/context-handoff-seed/test/smoke.test.js",
    "test:core": "node --test test/*.test.js",
    "test:features": "node local-features/dist/flow/test/flow-feature.test.js && node local-features/dist/context-compaction-mirror/test/smoke.test.js && node local-features/dist/checkpoint/test/smoke.test.js && node local-features/dist/dispatch/test/smoke.test.js && node local-features/dist/context-handoff-seed/test/smoke.test.js",
    "pretest:features": "npm run build:local-features"
  },
  "dependencies": {
    "@agentdev/audio-feedback-feature": "file:resources/features/agentdev-audio-feedback-feature-0.1.0.tgz",
    "@agentdev/audit-feature": "file:resources/features/agentdev-audit-feature-0.1.0.tgz",
    "@agentdev/lsp-feature": "file:resources/features/agentdev-lsp-feature-0.1.0.tgz",
    "@agentdev/memory-feature": "file:resources/features/agentdev-memory-feature-0.1.0.tgz",
    "@agentdev/plugin-compat-feature": "file:resources/features/agentdev-plugin-compat-feature-0.1.0.tgz",
    "@agentdev/qqbot-feature": "file:resources/features/agentdev-qqbot-feature-0.2.0.tgz",
    "@agentdev/shell-feature": "file:resources/features/agentdev-shell-feature-0.1.0.tgz",
    "@agentdev/tts-feature": "file:resources/features/agentdev-tts-feature-0.1.0.tgz",
    "@agentdev/visual-feature": "file:resources/features/agentdev-visual-feature-0.1.0.tgz",
    "@agentdev/websearch-feature": "file:resources/features/agentdev-websearch-feature-0.1.0.tgz",
    "@agentdev/weixin-bot": "file:resources/features/agentdev-weixin-bot-0.2.0.tgz",
    "@agentdev/feishu-bot": "file:resources/features/agentdev-feishu-bot-0.1.0.tgz",
    "@agentdev/wecom-bot": "file:resources/features/agentdev-wecom-bot-0.1.0.tgz",
    "agentdev": "^0.2.1",
    "express": "^4.21.2",
    "marked": "^18.0.4",
    "multer": "^2.1.1",
    "undici": "^7.25.0"
  },
  "bin": {
    "claw": "./bin/claw.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
